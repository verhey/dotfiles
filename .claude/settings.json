{
  "includeCoAuthoredBy": true,
  "permissions": {
    "allow": [
      "Fetch",
      "WebFetch",
      "WebSearch",
      "Bash(awk:*)",
      "Bash(cat:*)",
      "Bash(diff:*)",
      "Bash(du:*)",
      "Bash(fd:*)",
      "Bash(file:*)",
      "Bash(find:*)",
      "Bash(head:*)",
      "Bash(jq:*)",
      "Bash(ls:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(sed:*)",
      "Bash(stat:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue status:*)",
      "Bash(gh issue view:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr status:*)",
      "Bash(gh pr view:*)",
      "Bash(gh search:*)",
    ],
    "deny": [
      "Read(.env*)"
    ],
  },
}
